{
  "manifest_version": 3,
  "name": "AI Phishing Guard",
  "version": "3.2",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ]
}
